{
    "identifier": "default",
    "description": "Default capability for Sound Ninja",
    "windows": [
        "main",
        "theme-creator"
    ],
    "permissions": [
        "core:webview:allow-create-webview-window",
        "core:window:allow-close",
        "core:window:allow-destroy",
        "core:window:allow-set-focus",
        "fs:allow-read-dir",
        "fs:allow-mkdir",
        "dialog:allow-save",
        "core:default",
        "fs:default",
        "fs:allow-appdata-read-recursive",
        "fs:allow-appdata-write-recursive",
        "fs:allow-appdata-meta-recursive",
        {
            "identifier": "fs:allow-mkdir",
            "allow": [
                {
                    "path": "$APPDATA/**"
                }
            ]
        },
        "dialog:default",
        "shell:allow-open",
        "sql:default",
        "sql:allow-load",
        "sql:allow-execute",
        "sql:allow-select",
        "sql:allow-close"
    ]
}