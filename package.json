{
  "name": "soundninja",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "dev": "nuxt dev --port 3000",
    "build": "nuxt generate",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "tauri:build:macos": "tauri build --target universal-apple-darwin",
    "tauri:serve": "tauri dev",
    "tauri": "tauri",
    "prettier-rust": "prettier --write \"src-tauri/src/**/*.rs\"",
    "version:major": "bun scripts/bump-version.mjs major",
    "version:minor": "bun scripts/bump-version.mjs minor",
    "version:patch": "bun scripts/bump-version.mjs patch"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.4.0",
    "@pinia/nuxt": "^0.11.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "4.4.8",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "prettier": "^3.9.4",
    "prettier-plugin-rust": "^0.1.9",
    "sass": "^1.101.0"
  }
}
